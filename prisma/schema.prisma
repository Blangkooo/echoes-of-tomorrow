datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// Auth.js v5 required models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  onboarded     Boolean   @default(false)

  accounts          Account[]
  sessions          Session[]
  echoes            Echo[]
  conversations     Conversation[]
  timeCapsules      TimeCapsule[]
  goals             Goal[]
  predictions       Prediction[]
  reflections       Reflection[]
  universes         UniverseScenario[]
  futureSelf        FutureSelfProfile?
  memories          Memory[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum EchoType {
  MESSAGE
  PREDICTION
  DREAM
  CHALLENGE
  GOAL
  MEMORY
  QUESTION
}

enum EchoMood {
  HOPEFUL
  ANXIOUS
  EXCITED
  REFLECTIVE
  DETERMINED
  NOSTALGIC
  INSPIRED
}

enum CapsuleDuration {
  ONE_MONTH
  ONE_YEAR
  FIVE_YEARS
  TEN_YEARS
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

enum AIMode {
  OPTIMISTIC
  REALISTIC
  MENTOR
  ENTREPRENEUR
  CREATIVE
}

enum MemoryType {
  ECHO
  REFLECTION
  GOAL
  PREDICTION
  CAPSULE
  MILESTONE
}

// ─────────────────────────────────────────────
// Application models
// ─────────────────────────────────────────────

model Echo {
  id             String    @id @default(cuid())
  userId         String
  type           EchoType
  title          String    @default("")
  content        String    @db.Text
  targetDate     DateTime?
  mood           EchoMood  @default(HOPEFUL)
  tags           String[]
  isPinned       Boolean   @default(false)
  futureResponse String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([userId, createdAt(sort: Desc)])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String?
  mode      AIMode    @default(MENTOR)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([userId, updatedAt(sort: Desc)])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // 'user' | 'assistant'
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model FutureSelfProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  futureYear  Int      @default(2034)
  coreValues  String[]
  lifeGoals   String[]
  bio         String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TimeCapsule {
  id           String          @id @default(cuid())
  userId       String
  title        String
  content      String          @db.Text
  lockedUntil  DateTime
  duration     CapsuleDuration
  isUnlocked   Boolean         @default(false)
  unlockedAt   DateTime?
  aiReflection String?         @db.Text
  tags         String[]
  mood         EchoMood
  createdAt    DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isUnlocked])
  @@index([userId, lockedUntil])
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?    @db.Text
  targetDate  DateTime?
  status      GoalStatus @default(ACTIVE)
  progress    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

model Prediction {
  id         String   @id @default(cuid())
  userId     String
  content    String   @db.Text
  targetYear Int
  isResolved Boolean  @default(false)
  outcome    String?  @db.Text
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Reflection {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  mood      EchoMood
  tags      String[]
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

model UniverseScenario {
  id             String   @id @default(cuid())
  userId         String
  title          String
  description    String   @db.Text
  decisionPoint  String   @db.Text
  divergenceYear Int
  timeline       String[]
  probability    Int      @default(50)
  mood           String
  isPublic       Boolean  @default(false)
  gradient       String   @default("from-amber-500 to-yellow-600")
  tags           String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
}

model Memory {
  id         String     @id @default(cuid())
  userId     String
  content    String     @db.Text
  type       MemoryType
  sourceId   String?
  importance Float      @default(1.0)
  tags       String[]
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([userId, importance(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}
